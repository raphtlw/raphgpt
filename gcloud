gcloud_cli_container_url="gcr.io/google.com/cloudsdktool/google-cloud-cli:debian_component_based"
gcloud_cli_container_name="gcloud-config-raph"

if ! docker ps -aqf "name=$gcloud_cli_container_name"; then
  echo "Not logged in yet. Logging in via gcloud cli..."

  docker run -it --name "$gcloud_cli_container_name" "$gcloud_cli_container_url" /bin/bash -c \
    "gcloud auth login && gcloud config set project raphGPT"

  echo "Welcome to gcloud cli!"
fi

docker run --rm --volumes-from "$gcloud_cli_container_name" -it "$gcloud_cli_container_url" gcloud "$@"
